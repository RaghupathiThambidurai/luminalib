# ============================================================
# LuminalLib Backend - Staging Configuration
# ============================================================
# This is for STAGING SERVER with local LLM and PostgreSQL
# ============================================================

APP_NAME=LuminalLib
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=staging

HOST=0.0.0.0
PORT=8000

# PostgreSQL database
DATABASE_URL=postgresql://luminallib:password@staging-db.internal:5432/luminallib

SECRET_KEY=staging-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== LLM PROVIDER SETTINGS ==========
# Using HuggingFace Llama 2 7B for good balance of quality and speed
# Running locally on GPU
LLM_PROVIDER=huggingface
HUGGINGFACE_MODEL=meta-llama/Llama-2-7b-chat
HUGGINGFACE_DEVICE=cuda
HUGGINGFACE_QUANTIZE=false

# ========== FILE STORAGE SETTINGS ==========
# Using local disk storage on staging server
STORAGE_TYPE=local
STORAGE_LOCAL_BASE_PATH=/mnt/luminallib/files
STORAGE_BASE_URL=https://staging.luminallib.com/files

# ========== CACHING SETTINGS ==========
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true

# ========== ASYNC WORKER SETTINGS ==========
CELERY_BROKER_URL=redis://localhost:6379
CELERY_RESULT_BACKEND=redis://localhost:6379
