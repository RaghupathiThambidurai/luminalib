# ============================================================
# LuminalLib Backend - Production Configuration
# ============================================================
# This is for PRODUCTION with OpenAI GPT-4 and AWS S3
# ⚠️  DO NOT commit this file with real credentials!
# Use AWS Secrets Manager or similar for production secrets
# ============================================================

APP_NAME=LuminalLib
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

HOST=0.0.0.0
PORT=8000

# ========== DATABASE SETTINGS ==========
# Production PostgreSQL with high availability
DATABASE_URL=postgresql://luminallib:${DB_PASSWORD}@prod-db-cluster.rds.amazonaws.com:5432/luminallib

# ========== SECURITY SETTINGS ==========
# Use AWS Secrets Manager / Parameter Store for these!
SECRET_KEY=${SECRET_KEY_FROM_SECRETS}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== LLM PROVIDER SETTINGS ==========
# Using OpenAI GPT-4 Turbo for best quality
# Costs: ~$0.03/1K input tokens, $0.06/1K output tokens
# For 100,000 users: ~$60/month
LLM_PROVIDER=openai
OPENAI_API_KEY=${OPENAI_API_KEY_FROM_SECRETS}
OPENAI_MODEL=gpt-4-turbo-preview

# ========== FILE STORAGE SETTINGS ==========
# Using AWS S3 with CloudFront CDN
STORAGE_TYPE=s3
AWS_ACCESS_KEY_ID=${AWS_KEY_FROM_SECRETS}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_FROM_SECRETS}
AWS_S3_BUCKET=luminallib-prod-books
AWS_S3_REGION=us-east-1
STORAGE_BASE_URL=https://cdn.luminallib.com

# ========== CORS SETTINGS ==========
CORS_ORIGINS=https://luminallib.com,https://www.luminallib.com

# ========== CACHING SETTINGS ==========
# ElastiCache Redis cluster
REDIS_URL=redis://luminallib-cache.vpc.amazonaws.com:6379
CACHE_ENABLED=true

# ========== ASYNC WORKER SETTINGS ==========
# SQS for message queue, similar Redis backend
CELERY_BROKER_URL=sqs://
CELERY_RESULT_BACKEND=redis://luminallib-cache.vpc.amazonaws.com:6379

# ========== LOGGING ==========
LOG_LEVEL=INFO

# ========== MONITORING ==========
# Sentry for error tracking
SENTRY_DSN=${SENTRY_DSN_FROM_SECRETS}

# ========== FEATURE FLAGS ==========
ENABLE_BOOK_SUMMARIZATION=true
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_RECOMMENDATIONS=true
