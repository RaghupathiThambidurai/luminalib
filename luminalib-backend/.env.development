# ============================================================
# LuminalLib Backend - Development Configuration
# ============================================================
# This is for LOCAL DEVELOPMENT with mock data
# Use the appropriate file for your environment:
#   - .env.development (this file) - Local development
#   - .env.staging - Staging server
#   - .env.production - Production server
# ============================================================

# ========== APPLICATION SETTINGS ==========
APP_NAME=LuminalLib
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ========== SERVER SETTINGS ==========
HOST=0.0.0.0
PORT=8000

# ========== DATABASE SETTINGS ==========
# Using SQLite for development (single file database)
# For PostgreSQL: postgresql://user:password@localhost/luminallib
DATABASE_URL=sqlite:///./luminallib.db

# ========== SECURITY SETTINGS ==========
# ⚠️  CHANGE IN PRODUCTION!
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== LLM PROVIDER SETTINGS ==========
# Mock adapter - perfect for development (instant, free)
# Options: mock, openai, huggingface
LLM_PROVIDER=huggingface

# OpenAI configuration (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-3.5-turbo

# HuggingFace configuration (used when LLM_PROVIDER=huggingface)
# HUGGINGFACE_MODEL=meta-llama/Llama-2-7b-chat
# HUGGINGFACE_DEVICE=cpu
# HUGGINGFACE_QUANTIZE=false

# ========== FILE STORAGE SETTINGS ==========
# Local disk storage - perfect for development
# Options: local, s3
STORAGE_TYPE=local
STORAGE_LOCAL_BASE_PATH=./files
STORAGE_BASE_URL=http://localhost:8000/files

# AWS S3 configuration (used when STORAGE_TYPE=s3)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=...
# AWS_S3_REGION=us-east-1

# ========== CACHING SETTINGS ==========
# Optional: Set to redis://localhost:6379 if you have Redis running
# REDIS_URL=redis://localhost:6379
CACHE_ENABLED=false

# ========== ASYNC WORKER SETTINGS ==========
# Optional: Set these if you have Celery + Redis running
# CELERY_BROKER_URL=redis://localhost:6379
# CELERY_RESULT_BACKEND=redis://localhost:6379
